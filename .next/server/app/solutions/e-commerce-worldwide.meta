{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/solutions/layout,_N_T_/solutions/[slug]/layout,_N_T_/solutions/[slug]/page,_N_T_/solutions/e-commerce-worldwide"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/solutions/$d$slug/__PAGE__",
    "/solutions/$d$slug",
    "/solutions",
    "/_index",
    "/_head"
  ]
}